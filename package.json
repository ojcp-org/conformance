{
  "name": "@ojcp/conformance",
  "version": "0.1.0",
  "description": "OJCP conformance test suite — validate provider implementations against the spec",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "ojcp-conformance": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "schemas/"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsdown src/index.ts src/cli.ts --dts --clean --target node20",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ && prettier --check src/",
    "lint:fix": "eslint --fix src/ && prettier --write src/",
    "sync-schemas": "tsx scripts/sync-schemas.ts",
    "prepack": "pnpm sync-schemas && pnpm build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "ojcp",
    "conformance",
    "mcp",
    "job-data",
    "open-standard",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ojcp-org/conformance.git"
  },
  "homepage": "https://ojcp.dev",
  "bugs": "https://github.com/ojcp-org/conformance/issues",
  "engines": {
    "node": ">=20"
  }
}
